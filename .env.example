# Copia estos nombres en la configuración de tu entorno.
# No guardes valores reales dentro del repositorio.
DB_URL=jdbc:postgresql://localhost:5432/nombre_base_datos
DB_USER=usuario_postgres
DB_PASSWORD=contraseña_segura

# Ajustes opcionales del pool de conexiones
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_CONNECTION_TIMEOUT_MS=10000

# Sesiones: usa false solamente durante desarrollo local por HTTP.
SESSION_COOKIE_SECURE=true

# Solo se usan si la tabla usuarios está vacía.
# Retíralas del entorno después de crear el primer administrador.
ADMIN_INITIAL_NAME=Administrador
ADMIN_INITIAL_USER=admin
ADMIN_INITIAL_PASSWORD=una_contraseña_larga_y_unica

# Web Push. Genera una pareja propia y conserva la clave privada como secreto.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=https://gps-control.onrender.com
